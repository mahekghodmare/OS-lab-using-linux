#include <stdio.h>

int main() {
    int frames, pages, i, j, k;
    int pageFaults = 0;

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    printf("Enter number of pages: ");
    scanf("%d", &pages);

    int ref[pages];
    int frame[frames];

    printf("Enter reference string:\n");
    for(i = 0; i < pages; i++) {
        scanf("%d", &ref[i]);
    }

    for(i = 0; i < frames; i++) {
        frame[i] = -1;
    }

    int index = 0;

    for(i = 0; i < pages; i++) {
        int found = 0;

        for(j = 0; j < frames; j++) {
            if(frame[j] == ref[i]) {
                found = 1;
                break;
            }
        }

        if(!found) {
            frame[index] = ref[i];
            index = (index + 1) % frames;
            pageFaults++;
        }

        printf("Frames: ");
        for(k = 0; k < frames; k++) {
            printf("%d ", frame[k]);
        }
        printf("\n");
    }

    printf("Total Page Faults = %d\n", pageFaults);

    return 0;
}
